<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
                      MinSize="1050 720"
                      SetSize="1050 720">
    <BoxContainer Orientation="Horizontal" HorizontalExpand="False" VerticalExpand="True">
        <PanelContainer HorizontalExpand="False" VerticalExpand="True" MinSize="280 0">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
            </PanelContainer.PanelOverride>

            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
                <controls:StripeBack>
                    <BoxContainer Orientation="Vertical" Margin="10 0">
                        <Label Name="PreviewNameText"
                                Access="Public"
                                HorizontalAlignment="Center"
                                StyleClasses="LabelHeadingBigger" />
                    </BoxContainer>
                </controls:StripeBack>
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              VerticalExpand="True"
                              MinSize="280 0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">

                    <BoxContainer Name="CharacterImageSection"
                                  Access="Public"
                                  Orientation="Vertical"
                                  HorizontalExpand="False"
                                  VerticalExpand="False"
                                  Visible="False">

                        <controls:StripeBack>
                            <Label Text="{Loc 'arcane-detail-examinable-tab-image'}"
                                   HorizontalAlignment="Center"
                                   StyleClasses="LabelSmall" />
                        </controls:StripeBack>

                        <PanelContainer StyleClasses="Inset"
                                        SetSize="260 260"
                                        MinSize="260 260"
                                        MaxSize="260 260"
                                        HorizontalExpand="False"
                                        VerticalExpand="False">
                            <PanelContainer.PanelOverride>
                                <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
                            </PanelContainer.PanelOverride>
                            <TextureRect Name="CharacterImage"
                                         Access="Public"
                                         SetSize="260 260"
                                         HorizontalExpand="False"
                                         VerticalExpand="False"
                                         CanShrink="True"
                                         Stretch="KeepAspectCentered" />
                        </PanelContainer>
                    </BoxContainer>

                    <PanelContainer MinSize="260 250"
                                    MaxSize="260 250"
                                    HorizontalExpand="False"
                                    VerticalExpand="False"
                                    Margin="10">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#2C2C2C" />
                        </PanelContainer.PanelOverride>
                        <SpriteView Name="TargetPreview"
                                    Access="Public"
                                    SetSize="260 250"
                                    Scale="8 8"
                                    OverrideDirection="South"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                    </PanelContainer>

                    <BoxContainer Orientation="Vertical" Margin="10 0">
                        <Label Name="PreviewGenderText"
                               Access="Public"
                               HorizontalAlignment="Center"
                               StyleClasses="LabelSmall" />
                    </BoxContainer>

                    <BoxContainer Orientation="Horizontal"
                                  HorizontalAlignment="Center"
                                  SeparationOverride="4"
                                  Margin="0 5 0 5">
                        <Button Name="RotateLeftButton" Access="Public" Text="⬅" StyleClasses="OpenRight" />
                        <Button Name="RotateRightButton" Access="Public" Text="➡" StyleClasses="OpenLeft" />
                    </BoxContainer>

                </BoxContainer>
            </BoxContainer>
        </PanelContainer>

        <customControls:VSeparator StyleClasses="LowDivider" Margin="0" />

        <BoxContainer Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      Margin="10 0">
            <TabContainer Name="PreviewTabs"
                          Access="Public"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          MinSize="0 150">
                <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
                    <PanelContainer StyleClasses="Inset" HorizontalExpand="True" VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
                        </PanelContainer.PanelOverride>
                        <ScrollContainer HScrollEnabled="False" VerticalExpand="True">
                            <RichTextLabel Name="PreviewAppearanceText"
                                           Access="Public"
                                           VerticalExpand="True"
                                           Margin="10" />
                        </ScrollContainer>
                    </PanelContainer>
                </BoxContainer>

                <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
                    <PanelContainer StyleClasses="Inset" HorizontalExpand="True" VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
                        </PanelContainer.PanelOverride>
                        <ScrollContainer HScrollEnabled="False" VerticalExpand="True">
                            <RichTextLabel Name="PreviewCharacterText"
                                           Access="Public"
                                           VerticalExpand="True"
                                           Margin="10" />
                        </ScrollContainer>
                    </PanelContainer>
                </BoxContainer>

                <BoxContainer Name="HiddenInfoTab"
                              Access="Public"
                              Orientation="Vertical"
                              HorizontalExpand="True"
                              VerticalExpand="True">
                    <PanelContainer StyleClasses="Inset" HorizontalExpand="True" VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
                        </PanelContainer.PanelOverride>
                        <ScrollContainer HScrollEnabled="False" VerticalExpand="True">
                            <BoxContainer Orientation="Vertical" VerticalExpand="True" Margin="10">
                                <BoxContainer Name="ExploitableSection"
                                              Access="Public"
                                              Orientation="Vertical"
                                              VerticalExpand="True">
                                    <controls:StripeBack>
                                        <Label Text="{Loc 'arcane-detail-examinable-exploitable'}"
                                               HorizontalAlignment="Center"
                                               StyleClasses="LabelSmall" />
                                    </controls:StripeBack>
                                    <RichTextLabel Name="PreviewExploitableText"
                                                   Access="Public"
                                                   MinSize="0 100"
                                                   Margin="5 10" />
                                </BoxContainer>

                                <BoxContainer Name="SecretsSection"
                                              Access="Public"
                                              Orientation="Vertical"
                                              VerticalExpand="True">
                                    <controls:StripeBack>
                                        <Label Text="{Loc 'arcane-detail-examinable-secrets'}"
                                               HorizontalAlignment="Center"
                                               StyleClasses="LabelSmall" />
                                    </controls:StripeBack>
                                    <RichTextLabel Name="PreviewSecretsText"
                                                   Access="Public"
                                                   MinSize="0 100"
                                                   Margin="5 10" />
                                </BoxContainer>
                            </BoxContainer>
                        </ScrollContainer>
                    </PanelContainer>
                </BoxContainer>

            </TabContainer>

            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          MinHeight="200"
                          MaxHeight="200"
                          Margin="0 10 0 10">
                <controls:StripeBack>
                    <Label Text="{Loc 'arcane-detail-examinable-ooc'}"
                           StyleClasses="LabelSmall"
                           HorizontalAlignment="Center" />
                </controls:StripeBack>
                <PanelContainer StyleClasses="Inset" HorizontalExpand="True" VerticalExpand="True">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat BackgroundColor="#1A1A1A" />
                    </PanelContainer.PanelOverride>
                    <ScrollContainer HScrollEnabled="False" VerticalExpand="True">
                        <BoxContainer Orientation="Vertical" VerticalExpand="True" Margin="5">
                            <RichTextLabel Name="PreviewOOCText" Access="Public" VerticalExpand="True" />
                            <BoxContainer Name="PersonalNotesSection"
                                          Access="Public"
                                          Orientation="Vertical"
                                          Margin="0 8 0 0">
                                <Label Text="{Loc 'arcane-detail-examinable-personal-notes'}"
                                       StyleClasses="LabelHeading" />
                                <RichTextLabel Name="PreviewPersonalNotesText" Access="Public" />
                            </BoxContainer>
                        </BoxContainer>
                    </ScrollContainer>
                </PanelContainer>
            </BoxContainer>

        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
